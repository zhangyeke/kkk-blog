generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id            Int          @id @default(autoincrement())
  categoryId    Int
  pv            Int?         @default(0)
  cover         String       @default("")
  tags          String       @default("")
  title         String       @default("")
  content       String       @default("")
  /// 文章状态 0：下架 1：正常 2：草稿
  status        Int?         @default(1)
  createdAt     DateTime?    @default(now()) @db.Timestamp(6)
  userId        String       @db.Uuid
  favoriteCount Int          @default(0)
  updatedAt     DateTime     @default(now()) @updatedAt
  favorites     Favorite[]
  category      PostCategory @relation(fields: [categoryId], references: [id])
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PostCategory {
  id        Int      @id @default(autoincrement())
  name      String
  icon      String?
  status    Int      @default(1)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt
  posts     Post[]
}

model User {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String     @default("NO_NAME")
  email         String     @unique(map: "user_email_idx")
  emailVerified DateTime?  @default(now()) @db.Timestamp(6)
  avatar        String?
  roles         String     @default("user")
  address       Json?      @db.Json
  createdAt     DateTime   @default(now()) @db.Timestamp(6)
  updatedAt     DateTime   @default(now()) @updatedAt
  password      String?
  // 生日，使用时间戳类型
  birthday      DateTime?  @db.Timestamp(6)
  // 性别
  gender        Int?
  accounts      Account[]
  favorites     Favorite[]
  footprints    Footprint[]
  posts         Post[]
  session       Session[]
  bookmarks     Bookmark[]
}

/// 书签分类
model BookmarkCategory {
  id        Int        @id @default(autoincrement())
  name      String
  /// 0：禁用 1：正常（与其它模型 status 约定一致时可按需扩展）
  status    Int        @default(1)
  createdAt DateTime   @default(now()) @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt
  bookmarks Bookmark[]
}

/// 书签
model Bookmark {
  id         Int              @id @default(autoincrement())
  /// 网站链接
  url        String
  title      String
  intro      String?          @default("")
  /// 网站 favicon 等图标地址
  icon       String?          @default("")
  /// 0：禁用 1：正常
  status     Int              @default(1)
  userId     String           @db.Uuid
  categoryId Int
  createdAt  DateTime         @default(now()) @db.Timestamp(6)
  updatedAt  DateTime         @default(now()) @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   BookmarkCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([categoryId])
}

/// 用户足迹
model Footprint {
  id        Int      @id @default(autoincrement())
  userId    String   @db.Uuid
  province  Int
  city      Int
  area      Int?
  address   String?
  album     String[] @default([])
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Favorite {
  userId    String   @db.Uuid
  postId    Int
  createdAt DateTime @default(now()) @db.Timestamp(6)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

model Account {
  userId            String   @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now()) @db.Timestamp(6)
  updatedAt         DateTime @default(now()) @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String   @db.Uuid
  expires      DateTime @db.Timestamp(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}
